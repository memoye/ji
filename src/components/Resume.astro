---
interface Experience {
  role: string;
  company: string;
  duration: string;
  achievements: string[];
}

const experiences: Experience[] = [
  {
    role: "Product Manager (Volunteer) ",
    company: "Futureholds Foundation, Awka",
    duration: "",
    achievements: [
      "Planned, coordinated, and managed community-focused programs and initiatives from concept development to execution.",
      "Developed program strategies, timelines, and communication plans to ensure successful delivery of organizational objectives.",
      "Created engaging written and visual content for program promotion, awareness campaigns, and stakeholder communication.",
      "Managed relationships with volunteers, partners, and stakeholders to improve collaboration and program impact.",
      "Coordinated events, tracked project progress, and prepared reports to evaluate outcomes and effectiveness.",
      "Applied strong storytelling and communication skills to amplify the foundation's mission and connect with target audiences.",
      "Supported digital engagement efforts through content planning, audience interaction, and brand communication.",
    ],
  },
  {
    role: "Marketing and Sales Representative ",
    company: "Oriflame, Lagos",
    duration: "",
    achievements: [
      "Sold Oriflame products, achieving sales targets through effective product knowledge and customer engagement",
      "Organized conferences and seminars to promote products and train new sales representatives. ",
      "Trained new salespeople on mastering product knowledge, using their accounts, and implementing effective sales techniques",
      "Provided personalized skincare consultations, helping customers identify their skin type and  recommending the right products.",
      "Built customer relationships by ensuring satisfaction and addressing any concerns promptly.",
    ],
  },
];

const education = {
  degree: "Bachelor of Science in Applied Microbiology and Brewing",
  school: "Nnamdi Azikiwe University Awka, Awka, Anambra State",
  year: "2024",
};
---

<section id="resume" class="py-24 bg-white">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center space-y-4 mb-16" data-animate>
      <h2
        class="text-4xl font-bold tracking-tight text-balance bg-clip-text text-transparent bg-gradient-to-r from-pink-500 via-purple-500 to-indigo-500"
      >
        My Experience & Education
      </h2>
      <div
        class="h-1 w-20 bg-gradient-to-r from-pink-500 via-purple-500 to-indigo-500 rounded-full mx-auto"
      >
      </div>
    </div>

    <div class="grid md:grid-cols-[2fr,1fr] gap-12">
      <!-- Experience Column -->
      <div class="space-y-12" data-animate>
        <h3 class="text-xl font-semibold text-gray-900">
          Professional Experience
        </h3>
        {
          experiences.map((exp) => (
            <div class="relative pl-8 before:absolute before:left-0 before:top-0 before:bottom-0 before:w-px before:bg-gradient-to-b before:from-pink-500 before:via-purple-500 before:to-indigo-500">
              <div class="space-y-2">
                <div class="flex justify-between items-baseline">
                  <h4 class="text-lg font-medium text-gray-900">{exp.role}</h4>
                  <span class="text-sm text-gray-500">{exp.duration}</span>
                </div>
                <p class="text-pink-500 font-medium">{exp.company}</p>
                <ul class="mt-4 space-y-2">
                  {exp.achievements.map((achievement) => (
                    <li class="flex items-start gap-2 text-gray-600">
                      <svg
                        class="w-5 h-5 text-pink-400 flex-shrink-0 mt-0.5"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M5 13l4 4L19 7"
                        />
                      </svg>
                      <span>{achievement}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          ))
        }
      </div>

      <!-- Education Column -->
      <div data-animate>
        <h3 class="text-xl font-semibold text-gray-900 mb-8">Education</h3>
        <div
          class="p-6 rounded-2xl bg-gradient-to-br from-gray-50 to-white ring-1 ring-gray-900/5"
        >
          <h4 class="text-lg font-medium text-gray-900">{education.degree}</h4>
          <p class="text-gray-600 mt-2">{education.school}</p>
          <p class="text-sm text-gray-500 mt-1">Class of {education.year}</p>
        </div>

        <!-- Download Resume Button -->
        <div class="mt-12" data-animate>
          <a
            href="/portfolio/Jessica_Iwuala.pdf"
            class="group relative inline-flex items-center justify-center gap-2 w-fit mx-auto p-4 text-sm font-semibold text-white rounded-xl bg-gradient-to-r from-pink-500 via-purple-500 to-indigo-500 hover:from-pink-600 hover:via-purple-600 hover:to-indigo-600 transition-all duration-300 shadow-lg shadow-pink-500/25 hover:shadow-pink-500/40"
            target="_blank"
          >
            <span>View My Full Resume</span>
            <svg
              class="w-4 h-4 transition-transform group-hover:translate-x-1"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
              ></path>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
